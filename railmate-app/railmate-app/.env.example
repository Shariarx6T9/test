# ─── Supabase ────────────────────────────────────────────────────────────────
# Required — get from: https://supabase.com/dashboard/project/<id>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Sentry (Error Monitoring) ───────────────────────────────────────────────
# Optional in dev, required for production builds.
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/123456

# ─── PostHog Analytics (optional) ────────────────────────────────────────────
# Enables product analytics. Remove if not using PostHog.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to 'true' to enable features in non-production builds
EXPO_PUBLIC_ENABLE_COMMUNITY_REPORTS=true
EXPO_PUBLIC_ENABLE_TRUST_SCORES=false
