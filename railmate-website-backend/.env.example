# ============================================================
# RailMate Bangladesh – Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Next.js ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://railmatebd.com

# ── Supabase ───────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ⚠️  SERVICE ROLE KEY – NEVER expose client-side
# Only used in server-side API routes via createAdminClient()
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ── Resend (Transactional Email) ────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The verified "From" address in Resend
EMAIL_FROM=noreply@railmatebd.com

# Default Reply-To for notifications
EMAIL_REPLY_TO=hello@railmatebd.com

# Where admin notifications are sent
ADMIN_EMAIL=team@railmatebd.com

# ── PostHog (Product Analytics) ─────────────────────────────
# https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Server-side ingestion key (project API key, same as above)
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxx

# ── Rate Limiting – Upstash Redis (Optional) ────────────────
# If not set, falls back to in-memory rate limiting (not suitable
# for multi-instance production deployments).
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxx

# ── Notes ───────────────────────────────────────────────────
# • All NEXT_PUBLIC_ variables are exposed to the browser.
# • SUPABASE_SERVICE_ROLE_KEY must stay server-side only.
# • Verify Resend sender domain before going to production.
# • Set NODE_ENV=production automatically in Vercel.
