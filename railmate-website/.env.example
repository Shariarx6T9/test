# ============================================================
# RAILMATE WEBSITE — Environment Variables
# Copy this to .env and fill in values. NEVER commit .env
# ============================================================

# ------------------------------------------------------------
# SUPABASE — supabase.com → your project → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://ntpyyntgkalozhdgrbs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Settings → API → Project API Keys → anon/public
SUPABASE_SERVICE_ROLE_KEY=            # Settings → API → Project API Keys → service_role (NEVER prefix with NEXT_PUBLIC_)

# ------------------------------------------------------------
# RESEND (contact form emails) — resend.com → API Keys → Create API Key
# ------------------------------------------------------------
RESEND_API_KEY=
CONTACT_TO_EMAIL=support@railmatebd.com

# ------------------------------------------------------------
# SITE CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://bhairail.vercel.app   # change to railmatebd.com after domain

# ------------------------------------------------------------
# APP DOWNLOAD LINKS — fill in after Play Store submission
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_PLAY_URL=#         # play.google.com/store/apps/details?id=com.railmate.bd
NEXT_PUBLIC_APP_STORE_URL=#           # apps.apple.com/... (Phase 2)
NEXT_PUBLIC_APK_DOWNLOAD_URL=#        # direct APK link for beta

# ------------------------------------------------------------
# POSTHOG (web analytics) — posthog.com → Project → Settings → Project API Key
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# PAYMENT FEATURE FLAGS — keep false until payment gateway is set up
# ------------------------------------------------------------
ENABLE_BKASH=false
ENABLE_NAGAD=false
ENABLE_BANK_GATEWAY=false